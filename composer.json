{
    "name": "psc-acme/formatter-billing",
    "description": "Package formatter-billing for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\FormatterBilling\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "symfony/validator": "^7.0",
        "webmozart/assert": "^1.0",
        "symfony/finder": "^7.0",
        "spatie/laravel-permission": "^6.0",
        "laravel/framework": "^11.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "webforge/object-asserter": "^2.0.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}